<?xml version="1.0"?>
<!--
    Puzzlebot URDF — Gazebo Edition
    ================================
    Extends the base Puzzlebot URDF with:
      - Collision geometries   (required for Gazebo physics)
      - Inertial parameters    (required for Gazebo physics)
      - lidar_link             (2D LIDAR sensor at top of chassis)
      - gazebo_ros_diff_drive  (publishes /odom and listens /cmd_vel)
      - gazebo_ros_ray_sensor  (publishes /scan as LaserScan)
      - Surface friction tags  (high mu for drive wheels, zero for caster)

    Coordinate conventions
    ======================
    All STL meshes are from puzzlebot_sim package (must be built in ros2_ws).
    Wheel separation : 0.190 m  (2 × 0.095 m, Y offsets of wheel joints)
    Wheel radius     : 0.050 m
    Wheel diameter   : 0.100 m
-->
<robot name="puzzlebot">

  <!-- ============================================================ -->
  <!--                           LINKS                              -->
  <!-- ============================================================ -->

  <!-- base_footprint: virtual ground-plane reference link -->
  <link name="base_footprint">
    <inertial>
      <mass value="0.001"/>
      <inertia ixx="0.000001" iyy="0.000001" izz="0.000001"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!-- base_link: chassis -->
  <link name="base_link">
    <visual>
      <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
      <geometry>
        <mesh filename="package://puzzlebot_sim/meshes/Puzzlebot_Jetson_Lidar_Edition_Base.stl"/>
      </geometry>
      <material name="light_grey">
        <color rgba="0.72 0.72 0.72 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0.0 0.0 0.02" rpy="0.0 0.0 0.0"/>
      <geometry>
        <box size="0.20 0.18 0.08"/>
      </geometry>
    </collision>
    <inertial>
      <!-- Approximate as solid box 0.20 x 0.18 x 0.08, mass 0.5 kg -->
      <mass value="0.5"/>
      <origin xyz="0.0 0.0 0.02"/>
      <inertia ixx="0.001617" iyy="0.001933" izz="0.003017"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!-- wheel_r_link: right drive wheel (y < 0) -->
  <link name="wheel_r_link">
    <visual>
      <origin xyz="0.0 0.0 0.0" rpy="1.5708 0.0 0.0"/>
      <geometry>
        <mesh filename="package://puzzlebot_sim/meshes/Puzzlebot_Wheel.stl"/>
      </geometry>
      <material name="wheel_orange">
        <color rgba="0.9 0.4 0.0 1.0"/>
      </material>
    </visual>
    <collision>
      <!-- Cylinder: axis along Y (after rpy="1.5708 0 0" rotation) -->
      <origin xyz="0.0 0.0 0.0" rpy="1.5708 0.0 0.0"/>
      <geometry>
        <cylinder radius="0.050" length="0.030"/>
      </geometry>
    </collision>
    <inertial>
      <!-- Hollow cylinder approximation, mass 0.05 kg, r=0.05, l=0.03 -->
      <mass value="0.05"/>
      <inertia ixx="0.0000338" iyy="0.0000338" izz="0.0000625"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!-- wheel_l_link: left drive wheel (y > 0) -->
  <link name="wheel_l_link">
    <visual>
      <origin xyz="0.0 0.0 0.0" rpy="1.5708 0.0 3.1416"/>
      <geometry>
        <mesh filename="package://puzzlebot_sim/meshes/Puzzlebot_Wheel.stl"/>
      </geometry>
      <material name="wheel_orange">
        <color rgba="0.9 0.4 0.0 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0.0 0.0 0.0" rpy="1.5708 0.0 0.0"/>
      <geometry>
        <cylinder radius="0.050" length="0.030"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.0000338" iyy="0.0000338" izz="0.0000625"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!-- caster_link: rear omni-directional caster ball -->
  <link name="caster_link">
    <visual>
      <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
      <geometry>
        <mesh filename="package://puzzlebot_sim/meshes/Puzzlebot_Caster_Wheel.stl"/>
      </geometry>
      <material name="caster_silver">
        <color rgba="0.60 0.60 0.65 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
      <geometry>
        <sphere radius="0.018"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.02"/>
      <inertia ixx="0.0000029" iyy="0.0000029" izz="0.0000029"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!-- lidar_link: 2D LIDAR sensor on top of chassis -->
  <link name="lidar_link">
    <visual>
      <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
      <geometry>
        <cylinder radius="0.025" length="0.04"/>
      </geometry>
      <material name="lidar_black">
        <color rgba="0.1 0.1 0.1 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
      <geometry>
        <cylinder radius="0.025" length="0.04"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.0000145" iyy="0.0000145" izz="0.0000156"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!-- ============================================================ -->
  <!--                           JOINTS                             -->
  <!-- ============================================================ -->

  <joint name="base_link_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0.0 0.0 0.05" rpy="0.0 0.0 0.0"/>
  </joint>

  <joint name="wheel_r_joint" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_r_link"/>
    <origin xyz="0.052 -0.095 -0.0025" rpy="0.0 0.0 0.0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.01" friction="0.0"/>
  </joint>

  <joint name="wheel_l_joint" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_l_link"/>
    <origin xyz="0.052 0.095 -0.0025" rpy="0.0 0.0 0.0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.01" friction="0.0"/>
  </joint>

  <joint name="caster_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster_link"/>
    <origin xyz="-0.095 0.0 -0.03" rpy="0.0 0.0 0.0"/>
  </joint>

  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child link="lidar_link"/>
    <origin xyz="0.0 0.0 0.12" rpy="0.0 0.0 0.0"/>
  </joint>

  <!-- ============================================================ -->
  <!--              GAZEBO PLUGIN: DIFFERENTIAL DRIVE               -->
  <!-- ============================================================ -->
  <gazebo>
    <plugin name="gazebo_ros_diff_drive" filename="libgazebo_ros_diff_drive.so">
      <ros>
        <namespace>/</namespace>
      </ros>
      <update_rate>30</update_rate>

      <!-- Wheel joints -->
      <left_joint>wheel_l_joint</left_joint>
      <right_joint>wheel_r_joint</right_joint>

      <!-- Kinematics -->
      <wheel_separation>0.190</wheel_separation>
      <wheel_diameter>0.100</wheel_diameter>

      <!-- Limits -->
      <max_wheel_torque>20.0</max_wheel_torque>
      <max_wheel_acceleration>1.0</max_wheel_acceleration>

      <!-- Topics -->
      <command_topic>cmd_vel</command_topic>

      <!-- Odometry -->
      <publish_odom>true</publish_odom>
      <publish_odom_tf>true</publish_odom_tf>
      <publish_wheel_tf>false</publish_wheel_tf>
      <odometry_frame>odom</odometry_frame>
      <robot_base_frame>base_footprint</robot_base_frame>
    </plugin>
  </gazebo>

  <!-- ============================================================ -->
  <!--              GAZEBO PLUGIN: 2D LIDAR (LASER SCAN)            -->
  <!-- ============================================================ -->
  <gazebo reference="lidar_link">
    <sensor type="ray" name="lidar_sensor">
      <pose>0 0 0 0 0 0</pose>
      <visualize>false</visualize>
      <update_rate>10</update_rate>
      <ray>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159265</min_angle>
            <max_angle>3.14159265</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.12</min>
          <max>5.0</max>
          <resolution>0.01</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.01</stddev>
        </noise>
      </ray>
      <plugin name="gazebo_ros_laser" filename="libgazebo_ros_ray_sensor.so">
        <ros>
          <remapping>~/out:=scan</remapping>
        </ros>
        <output_type>sensor_msgs/LaserScan</output_type>
        <frame_name>lidar_link</frame_name>
      </plugin>
    </sensor>
  </gazebo>

  <!-- ============================================================ -->
  <!--              GAZEBO SURFACE FRICTION                         -->
  <!-- ============================================================ -->

  <!-- Drive wheels: high traction -->
  <gazebo reference="wheel_r_link">
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
    <kp>500000.0</kp>
    <kd>10.0</kd>
    <minDepth>0.001</minDepth>
    <maxVel>0.1</maxVel>
  </gazebo>

  <gazebo reference="wheel_l_link">
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
    <kp>500000.0</kp>
    <kd>10.0</kd>
    <minDepth>0.001</minDepth>
    <maxVel>0.1</maxVel>
  </gazebo>

  <!-- Caster: frictionless so it slides freely -->
  <gazebo reference="caster_link">
    <mu1>0.0</mu1>
    <mu2>0.0</mu2>
    <kp>100000.0</kp>
    <kd>10.0</kd>
  </gazebo>

</robot>
