<?xml version="1.0"?>
<!--
    Puzzlebot URDF Description
    ===========================
    Describes the Puzzlebot differential drive robot as a tree of links and joints.

    TF Tree
    =======
    map (fixed frame)
      odom              [static tf, published by launch file]
        base_footprint  [dynamic tf, published by joint_state_publisher node]
          base_link     [fixed joint: base_link_joint]
            wheel_r_link  [continuous joint: wheel_r_joint]
            wheel_l_link  [continuous joint: wheel_l_joint]
            caster_link   [fixed joint: caster_joint]

    Joint Offsets  (from challenge specification)
    ==============================================
    base_link_joint : base_footprint -> base_link      x=0.000  y=0.000  z=0.050
    wheel_r_joint   : base_link      -> wheel_r_link   x=0.052  y=-0.095 z=-0.0025
    wheel_l_joint   : base_link      -> wheel_l_link   x=0.052  y=0.095  z=-0.0025
    caster_joint    : base_link      -> caster_link    x=-0.095 y=0.000  z=-0.030

    Mesh files
    ==========
    base_link    : Puzzlebot_Jetson_Lidar_Edition_Base.stl
    wheel_r_link : Puzzlebot_Wheel.stl
    wheel_l_link : Puzzlebot_Wheel.stl
    caster_link  : Puzzlebot_Caster_Wheel.stl

    Note: STL files are off-centre in their local coordinate frame. The visual <origin>
    elements below have been set to align them as closely as possible. Use a CAD tool
    to measure exact offsets if fine-tuning is needed.
-->
<robot name="puzzlebot">

  <!-- ========================================================= -->
  <!--                          LINKS                            -->
  <!-- ========================================================= -->

  <!-- base_footprint: virtual link that represents the robot pose in the 2D XY plane.
       It has no visual geometry; its sole purpose is to anchor the robot in the world. -->
  <link name="base_footprint"/>

  <!-- base_link: physical chassis of the Puzzlebot -->
  <link name="base_link">
    <visual>
      <!-- The STL is exported with the robot front along +X and the flat base
           resting on the XY plane. No rotation is required. If the chassis
           appears to face the wrong direction, try rpy="0 0 1.5708" (90 deg yaw)
           or rpy="0 0 -1.5708" depending on how the original CAD was exported. -->
      <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
      <geometry>
        <mesh filename="package://puzzlebot_sim/meshes/Puzzlebot_Jetson_Lidar_Edition_Base.stl"/>
      </geometry>
      <material name="light_grey">
        <color rgba="0.72 0.72 0.72 1.0"/>
      </material>
    </visual>
  </link>

  <!-- wheel_r_link: right wheel (negative Y side in the robot frame) -->
  <link name="wheel_r_link">
    <visual>
      <!-- The wheel STL hub faces +Z in its local frame. Rotating 90 deg around X
           makes the hub face +Y, which is perpendicular to the spin axis (Y).
           For the right wheel (at y=-0.095) this points the face outward (-Y global). -->
      <origin xyz="0.0 0.0 0.0" rpy="1.5708 0.0 0.0"/>
      <geometry>
        <mesh filename="package://puzzlebot_sim/meshes/Puzzlebot_Wheel.stl"/>
      </geometry>
      <material name="wheel_orange">
        <color rgba="0.9 0.4 0.0 1.0"/>
      </material>
    </visual>
  </link>

  <!-- wheel_l_link: left wheel (positive Y side in the robot frame) -->
  <link name="wheel_l_link">
    <visual>
      <!-- Same roll as the right wheel. A 180-deg yaw is added so the hub face
           points outward (+Y) on the left side instead of inward. -->
      <origin xyz="0.0 0.0 0.0" rpy="1.5708 0.0 3.1416"/>
      <geometry>
        <mesh filename="package://puzzlebot_sim/meshes/Puzzlebot_Wheel.stl"/>
      </geometry>
      <material name="wheel_orange">
        <color rgba="0.9 0.4 0.0 1.0"/>
      </material>
    </visual>
  </link>

  <!-- caster_link: omnidirectional caster ball at the rear of the chassis -->
  <link name="caster_link">
    <visual>
      <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
      <geometry>
        <mesh filename="package://puzzlebot_sim/meshes/Puzzlebot_Caster_Wheel.stl"/>
      </geometry>
      <material name="caster_silver">
        <color rgba="0.60 0.60 0.65 1.0"/>
      </material>
    </visual>
  </link>

  <!-- ========================================================= -->
  <!--                          JOINTS                           -->
  <!-- ========================================================= -->

  <!-- Fixed joint: lifts base_link 5 cm above the ground plane
       represented by base_footprint. -->
  <joint name="base_link_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0.0 0.0 0.05" rpy="0.0 0.0 0.0"/>
  </joint>

  <!-- Continuous joint: right wheel can spin freely around the Y axis. -->
  <joint name="wheel_r_joint" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_r_link"/>
    <origin xyz="0.052 -0.095 -0.0025" rpy="0.0 0.0 0.0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- Continuous joint: left wheel can spin freely around the Y axis. -->
  <joint name="wheel_l_joint" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_l_link"/>
    <origin xyz="0.052 0.095 -0.0025" rpy="0.0 0.0 0.0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- Fixed joint: caster ball is rigidly attached at the rear of the chassis. -->
  <joint name="caster_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster_link"/>
    <origin xyz="-0.095 0.0 -0.03" rpy="0.0 0.0 0.0"/>
  </joint>

</robot>
